# Single-host environment variables for Render/Koyeb/Railway

JWT_SECRET=replace-with-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/database
APP_BASE_URL=https://your-app-domain.onrender.com
# Leave empty for one-domain deploy where frontend and backend run together.
CORS_ORIGINS=
AUTO_JOIN_DEFAULT_CHATS=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
