# Single-host environment variables for Render/Koyeb/Railway

JWT_SECRET=replace-with-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/database
DATA_DIR=
REQUIRE_PERSISTENT_DB=true
APP_BASE_URL=https://your-app-domain.onrender.com
# Leave empty for one-domain deploy where frontend and backend run together.
CORS_ORIGINS=
AUTO_JOIN_DEFAULT_CHATS=false
SEED_DEMO_DATA=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
ICE_SERVERS_JSON=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=mirx-media
MEDIA_FOLDER_PREFIX=mirx
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
