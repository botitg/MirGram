# Single-host environment variables for Render/Koyeb/Railway

JWT_SECRET=replace-with-long-random-secret
# Use Supabase Connect -> Session pooler on Render, not the direct db.<project>.supabase.co host.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
DATA_DIR=
REQUIRE_PERSISTENT_DB=true
APP_BASE_URL=https://your-app-domain.onrender.com
# Leave empty for one-domain deploy where frontend and backend run together.
CORS_ORIGINS=
AUTO_JOIN_DEFAULT_CHATS=true
SEED_DEMO_DATA=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
ICE_SERVERS_JSON=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=mirx-media
MEDIA_FOLDER_PREFIX=mirx
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
