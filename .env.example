# Backend local development (.env)

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
# On Render with Supabase use Connect -> Session pooler, not db.<project>.supabase.co:5432.
DATABASE_URL=
DATA_DIR=
REQUIRE_PERSISTENT_DB=false

# Public app URL used to build absolute media URLs.
# In one-host deployment this is the same domain where frontend opens.
APP_BASE_URL=http://localhost:3000

# Leave empty for one-domain deploy where frontend and backend run together.
# Comma-separated list. Use * only for debugging.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8888

# If true, new users are auto-added to chats marked as default.
AUTO_JOIN_DEFAULT_CHATS=true

# If true, the server creates demo accounts and a lobby on an empty database.
SEED_DEMO_DATA=false

# Optional browser push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional TURN/STUN config for WebRTC calls. Must be a JSON array.
# Example:
# ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
ICE_SERVERS_JSON=

# Optional Supabase Storage for persistent uploads.
# Requires a public bucket in your Supabase project.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=mirx-media

# Shared remote media prefix for Supabase/Cloudinary folders.
MEDIA_FOLDER_PREFIX=mirx

# Optional Cloudinary storage fallback.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
