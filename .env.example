# Backend local development (.env)

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# Public backend URL used to build absolute media URLs.
# For local run keep localhost.
APP_BASE_URL=http://localhost:3000

# Allowed origins for browser requests and Socket.IO.
# Comma-separated list. Use * only for debugging.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8888

# If true, new users are auto-added to default chats.
AUTO_JOIN_DEFAULT_CHATS=false
